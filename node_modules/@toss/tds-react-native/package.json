{
  "name": "@toss/tds-react-native",
  "version": "2.0.3",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "license": "GPL-3.0",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./private": {
      "require": {
        "types": "./dist/cjs/private/index.d.ts",
        "default": "./dist/cjs/private/index.js"
      },
      "import": {
        "types": "./dist/esm/private/index.d.ts",
        "default": "./dist/esm/private/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "js-obfuscate": "sh ./obfuscate.sh",
    "string-obfuscate": "yarn obfuscate dist",
    "prepack": "yarn build",
    "build": "./scripts/build.sh",
    "test": "jest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.spec.json",
    "lint": "eslint ./src/**/*.{js,jsx,ts,tsx}"
  },
  "devDependencies": {
    "@babel/runtime": "7.18.9",
    "@granite-js/native": "1.0.18",
    "@granite-js/react-native": "1.0.18",
    "@jest/globals": "^28",
    "@testing-library/react-native": "^12.4.1",
    "@tools/javascript-obfuscator": "0.0.1",
    "@tools/obfuscator": "0.0.1",
    "@types/culori": "^2.1.1",
    "@types/jest": "^29",
    "@types/react": "19.2.3",
    "babel-preset-granite": "1.0.18",
    "brick-module": "0.5.0",
    "esbuild": "^0.25.8",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-react-native": "^18.0.0",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-test-renderer": "19.2.3",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@granite-js/native": ">=1",
    "@granite-js/react-native": ">=1",
    "brick-module": "*",
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "@react-spring/native": "10.0.3",
    "@react-stately/radio": "^3.11.3",
    "@toss/tds-color-utils": "0.0.2",
    "@toss/tds-colors": "^0.1.0",
    "@toss/tds-easings": "^0.0.1",
    "@toss/tds-spring-easing": "^0.0.1",
    "@toss/tds-typography": "0.0.3",
    "@toss/utils": "^1.6.1",
    "@types/node": "22.15.0",
    "culori": "^4.0.1",
    "es-hangul": "^2.3.0",
    "hex-to-rgba": "^2.0.1"
  },
  "sideEffects": false,
  "packageManager": "yarn@3.2.1",
  "files": [
    "dist"
  ]
}