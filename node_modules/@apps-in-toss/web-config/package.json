{
  "name": "@apps-in-toss/web-config",
  "type": "module",
  "version": "2.4.7",
  "description": "Shared build utilities for Apps In Toss",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsup"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@babel/core": "7.23.9",
    "@babel/traverse": "^7.26.9",
    "@babel/types": "^7.26.9",
    "@granite-js/utils": "1.0.18",
    "cosmiconfig": "^9.0.0",
    "cosmiconfig-typescript-loader": "^5.1.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7",
    "@types/node": "^22.10.2",
    "eslint": "^9.7.0",
    "tsup": "^8.3.5",
    "typescript": "5.8.3"
  }
}