{
  "name": "@apps-in-toss/ait-format-proto",
  "version": "1.0.0",
  "description": "Generated protobuf types for AIT format (internal)",
  "main": "./dist/ait/v1/ait.js",
  "types": "./dist/ait/v1/ait.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ait/v1/ait.js",
      "require": "./dist/ait/v1/ait.js",
      "types": "./dist/ait/v1/ait.d.ts"
    },
    "./ait/v1": {
      "import": "./dist/ait/v1/ait.js",
      "require": "./dist/ait/v1/ait.js",
      "types": "./dist/ait/v1/ait.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "long": "^5.3.2",
    "protobufjs": "^7.5.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  }
}