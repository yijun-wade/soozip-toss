{
  "name": "@apps-in-toss/plugins",
  "type": "module",
  "version": "2.4.7",
  "description": "The plugins for Apps In Toss",
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsup"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@ryoppippi/unplugin-typia": "^2.6.5",
    "@types/archiver": "^6.0.3",
    "@types/connect": "^3",
    "tsup": "^8.4.0",
    "typescript": "5.8.3",
    "typia": "^9.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@apps-in-toss/ait-format": "1.0.0",
    "@apps-in-toss/plugin-compat": "2.4.7",
    "@granite-js/plugin-core": "1.0.18",
    "@granite-js/plugin-micro-frontend": "1.0.18",
    "@granite-js/plugin-sentry": "1.0.18",
    "@granite-js/utils": "1.0.18",
    "archiver": "^7.0.1",
    "connect": "^3.7.0",
    "esbuild": "0.25.5",
    "execa": "9.3.0",
    "picocolors": "^1.1.1",
    "uuidv7": "^1.0.2"
  }
}