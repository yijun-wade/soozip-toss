{
  "name": "@apps-in-toss/native-modules",
  "type": "module",
  "version": "2.4.7",
  "description": "Native Modules for Apps In Toss",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsup"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./async-bridges": "./src/async-bridges.ts",
    "./constant-bridges": "./src/constant-bridges.ts",
    "./event-bridges": "./src/event-bridges.ts",
    "./bridges-meta.json": "./dist/bridges-meta.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@babel/runtime": "^7",
    "@granite-js/native": "1.0.18",
    "@granite-js/react-native": "1.0.18",
    "@types/react": "19.2.3",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "0.25.5",
    "picocolors": "^1.1.1",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "tsup": "^8.5.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@apps-in-toss/types": "2.4.7",
    "brick-module": "0.5.0",
    "es-toolkit": "^1.39.3"
  },
  "peerDependencies": {
    "@granite-js/native": "*",
    "@granite-js/react-native": "*",
    "react": "*",
    "react-native": "*"
  },
  "brickModule": {
    "specSrc": "./src/spec"
  }
}