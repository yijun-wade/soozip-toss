{
  "name": "@granite-js/video",
  "version": "1.0.18",
  "description": "Pluggable video component for React Native with provider selection",
  "type": "module",
  "main": "./dist/module/index.js",
  "types": "./dist/typescript/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/typescript/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "android",
    "ios",
    "*.podspec",
    "react-native.config.js",
    "!example/**",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "prepack": "yarn build",
    "example": "yarn workspace @granite-js/video-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "bob build && tsc --project tsconfig.build.json"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "video",
    "player",
    "exoplayer",
    "avplayer",
    "vlc",
    "streaming",
    "hls",
    "dash",
    "drm",
    "pluggable",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toss/granite.git",
    "directory": "packages/video"
  },
  "author": "Toss <platform@toss.im>",
  "homepage": "https://github.com/toss/granite/tree/main/packages/video#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "19.2.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.7.0",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-builder-bob": "0.40.17",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "GraniteVideoViewSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "run.granite.video"
    },
    "ios": {
      "componentProvider": {
        "GraniteVideoView": "GraniteVideoView"
      }
    }
  },
  "sideEffects": false,
  "react-native-builder-bob": {
    "source": "src",
    "output": "dist",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ]
    ]
  }
}